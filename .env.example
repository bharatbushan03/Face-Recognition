# Face Recognition Attendance - Environment Configuration
# Copy to .env and update values for your environment.
# Never commit real credentials.

# Logging
FR_LOG_LEVEL=INFO

# CORS origins for frontend access
FR_CORS_ORIGINS=http://localhost,http://127.0.0.1

# API recognition threshold
# Lower values = stricter matching, fewer false positives.
FR_RECOGNITION_TOLERANCE=0.5

# Optional admin auth (protects register and users endpoints)
# Leave empty to disable auth in local development.
FR_ADMIN_USERNAME=
FR_ADMIN_PASSWORD=
